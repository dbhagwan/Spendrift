# Server
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/spendrift

# Plaid — create credentials at https://dashboard.plaid.com
# TODO(production): use the production environment and rotate secrets via your secret manager.
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox
# Public URL Plaid should deliver webhooks to (e.g. https://api.spendrift.app/webhooks/plaid)
PLAID_WEBHOOK_URL=

# Anthropic — powers categorization fallback, receipt extraction, and insight narration.
# TODO(production): store in a secret manager, never commit.
ANTHROPIC_API_KEY=your-anthropic-api-key
